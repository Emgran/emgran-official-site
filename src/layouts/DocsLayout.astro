---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Emgran 文档" } = Astro.props;
---

<Layout title={title} description={description}>
  <div class="docs-container">
    <aside class="docs-sidebar">
      <nav class="docs-nav">
        <h3>文档导航</h3>
        <ul>
          <li><a href="/docs">文档首页</a></li>
          <li><a href="/docs/getting-started">快速开始</a></li>
          <li><a href="/docs/concepts">核心概念</a></li>
          <li><a href="/docs/guides">使用指南</a></li>
          <li><a href="/docs/api">API 参考</a></li>
        </ul>
      </nav>
    </aside>
    <main class="docs-content">
      <h1>{title}</h1>
      <slot />
    </main>
  </div>
</Layout>

<style>
  .docs-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 3rem;
  }

  .docs-sidebar {
    position: sticky;
    top: 5rem;
    height: fit-content;
  }

  .docs-nav h3 {
    font-size: 1.1rem;
    color: #1f2937;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }

  .docs-nav ul {
    list-style: none;
  }

  .docs-nav li {
    margin-bottom: 0.5rem;
  }

  .docs-nav a {
    color: #4b5563;
    text-decoration: none;
    padding: 0.5rem;
    display: block;
    border-radius: 0.25rem;
    transition: all 0.3s;
  }

  .docs-nav a:hover {
    background: #f3f4f6;
    color: #2563eb;
  }

  .docs-content {
    min-width: 0;
  }

  .docs-content h1 {
    font-size: 2.5rem;
    color: #1f2937;
    margin-bottom: 1.5rem;
  }

  .docs-content h2 {
    font-size: 1.8rem;
    color: #1f2937;
    margin: 2rem 0 1rem;
  }

  .docs-content h3 {
    font-size: 1.4rem;
    color: #374151;
    margin: 1.5rem 0 0.75rem;
  }

  .docs-content p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .docs-content ul, .docs-content ol {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .docs-content li {
    margin-bottom: 0.5rem;
  }

  .docs-content code {
    background: #f3f4f6;
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-family: 'Monaco', 'Consolas', monospace;
    font-size: 0.9em;
  }

  .docs-content pre {
    background: #1f2937;
    color: #f9fafb;
    padding: 1.5rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .docs-content pre code {
    background: none;
    padding: 0;
    color: inherit;
  }

  @media (max-width: 768px) {
    .docs-container {
      grid-template-columns: 1fr;
    }

    .docs-sidebar {
      position: static;
      margin-bottom: 2rem;
    }
  }
</style>
