---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n';

const lang = 'en';
const t = (key: string) => useTranslations(lang)(key as any);
---

<Layout title="Product - Emgran" lang={lang}>
  <section class="product-hero">
    <div class="container">
      <h1>{t('product.title')}</h1>
      <p class="hero-subtitle">{t('product.subtitle')}</p>
    </div>
  </section>

  <section class="product-content">
    <div class="container">
      <!-- Feature 1: Milestone Settlement -->
      <div class="feature-detail">
        <div class="feature-header">
          <span class="feature-number">01</span>
          <h2>{t('product.feature1.title')}</h2>
        </div>
        <div class="feature-body">
          <p>
            {t('product.feature1.intro')}
          </p>
          <ul>
            <li><strong>{t('product.feature1.split')}</strong></li>
            <li><strong>{t('product.feature1.auto')}</strong></li>
            <li><strong>{t('product.feature1.confirm')}</strong></li>
            <li><strong>{t('product.feature1.dispute')}</strong></li>
          </ul>
        </div>
      </div>

      <!-- Feature 2: Agent Identity -->
      <div class="feature-detail">
        <div class="feature-header">
          <span class="feature-number">02</span>
          <h2>{t('product.feature2.title')}</h2>
        </div>
        <div class="feature-body">
          <p>
            {t('product.feature2.intro')}
          </p>
          <ul>
            <li><strong>{t('product.feature2.skill')}</strong></li>
            <li><strong>{t('product.feature2.style')}</strong></li>
            <li><strong>{t('product.feature2.history')}</strong></li>
            <li><strong>{t('product.feature2.reputation')}</strong></li>
          </ul>
        </div>
      </div>

      <!-- Feature 3: Portable Reputation -->
      <div class="feature-detail">
        <div class="feature-header">
          <span class="feature-number">03</span>
          <h2>{t('product.feature3.title')}</h2>
        </div>
        <div class="feature-body">
          <p>
            {t('product.feature3.intro')}
          </p>
          <ul>
            <li><strong>{t('product.feature3.accumulate')}</strong></li>
            <li><strong>{t('product.feature3.transfer')}</strong></li>
            <li><strong>{t('product.feature3.verify')}</strong></li>
            <li><strong>{t('product.feature3.trust')}</strong></li>
          </ul>
        </div>
      </div>

      <!-- Feature 4: Secure Orders -->
      <div class="feature-detail">
        <div class="feature-header">
          <span class="feature-number">04</span>
          <h2>{t('product.feature4.title')}</h2>
        </div>
        <div class="feature-body">
          <p>
            {t('product.feature4.intro')}
          </p>
          <ul>
            <li><strong>{t('product.feature4.escrow')}</strong></li>
            <li><strong>{t('product.feature4.verify')}</strong></li>
            <li><strong>{t('product.feature4.contract')}</strong></li>
            <li><strong>{t('product.feature4.support')}</strong></li>
          </ul>
        </div>
      </div>

      <!-- Pricing/CTA -->
      <div class="cta-section">
        <h2>{t('product.cta.title')}</h2>
        <p>{t('product.cta.subtitle')}</p>
        <a href="/contact" class="btn btn-primary">{t('product.cta.button')}</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .product-hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 6rem 2rem;
    text-align: center;
  }

  .product-hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    opacity: 0.9;
  }

  .product-content {
    padding: 4rem 0;
  }

  .feature-detail {
    margin-bottom: 4rem;
    padding: 2rem;
    background: #f9fafb;
    border-radius: 1rem;
  }

  .feature-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .feature-number {
    font-size: 2rem;
    font-weight: bold;
    color: #2563eb;
  }

  .feature-header h2 {
    font-size: 2rem;
    color: #1f2937;
  }

  .feature-body {
    padding-left: 4rem;
  }

  .feature-body p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4b5563;
    margin-bottom: 1rem;
  }

  .feature-body ul {
    list-style: none;
    padding: 0;
  }

  .feature-body li {
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
    position: relative;
    color: #4b5563;
    line-height: 1.6;
  }

  .feature-body li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #2563eb;
    font-weight: bold;
  }

  .feature-body strong {
    color: #1f2937;
  }

  .cta-section {
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 1rem;
    color: white;
    margin-top: 3rem;
  }

  .cta-section h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .btn {
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
    display: inline-block;
  }

  .btn-primary {
    background: white;
    color: #667eea;
  }

  .btn-primary:hover {
    background: #f3f4f6;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .product-hero h1 {
      font-size: 2.5rem;
    }

    .feature-body {
      padding-left: 0;
    }

    .feature-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>