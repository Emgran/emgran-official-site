---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n';

const lang = 'zh';
const t = (key: string) => useTranslations(lang)(key as any);
---

<Layout title="关于我们 - Emgran" lang={lang}>
  <section class="about-hero">
    <div class="container">
      <h1>{t('about.title')}</h1>
      <p class="hero-subtitle">{t('about.subtitle')}</p>
    </div>
  </section>

  <section class="about-content">
    <div class="container">
      <div class="about-section">
        <h2>{t('about.mission.title')}</h2>
        <p>
          {t('about.mission.desc')}
        </p>
      </div>

      <div class="about-section">
        <h2>{t('about.vision.title')}</h2>
        <p>
          {t('about.vision.desc')}
        </p>
      </div>

      <div class="about-section">
        <h2>{t('about.team.title')}</h2>
        <div class="team-grid">
          <div class="team-member">
            <h3>{t('about.team.tech')}</h3>
            <p>{t('about.team.tech.desc')}</p>
          </div>
          <div class="team-member">
            <h3>{t('about.team.design')}</h3>
            <p>{t('about.team.design.desc')}</p>
          </div>
          <div class="team-member">
            <h3>{t('about.team.ops')}</h3>
            <p>{t('about.team.ops.desc')}</p>
          </div>
        </div>
      </div>

      <div class="about-section">
        <h2>{t('about.contact')}</h2>
        <p>
          {t('about.contact.desc')} <a href="/zh/contact">{t('about.contact.link')}</a>。
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .about-hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 6rem 2rem;
    text-align: center;
  }

  .about-hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    opacity: 0.9;
  }

  .about-content {
    padding: 4rem 0;
  }

  .about-section {
    margin-bottom: 3rem;
  }

  .about-section h2 {
    font-size: 2rem;
    color: #1f2937;
    margin-bottom: 1.5rem;
  }

  .about-section p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4b5563;
  }

  .about-section a {
    color: #2563eb;
    text-decoration: none;
  }

  .about-section a:hover {
    text-decoration: underline;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .team-member {
    background: #f9fafb;
    padding: 2rem;
    border-radius: 1rem;
    border-left: 4px solid #2563eb;
  }

  .team-member h3 {
    font-size: 1.3rem;
    color: #1f2937;
    margin-bottom: 0.75rem;
  }

  .team-member p {
    color: #6b7280;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .about-hero h1 {
      font-size: 2.5rem;
    }
  }
</style>