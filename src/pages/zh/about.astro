---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n';

const lang = 'zh';
const t = (key: string) => useTranslations(lang)(key as any);
---

<Layout title="关于我们 - Emgran" lang={lang}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-indigo-600 to-purple-700 text-white py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{t('about.title')}</h1>
      <p class="text-xl md:text-2xl opacity-90">{t('about.subtitle')}</p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto space-y-12">
      
      <!-- Mission -->
      <div>
        <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">{t('about.mission.title')}</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed">{t('about.mission.desc')}</p>
      </div>

      <!-- Vision -->
      <div>
        <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">{t('about.vision.title')}</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed">{t('about.vision.desc')}</p>
      </div>

      <!-- Team -->
      <div>
        <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-6">{t('about.team.title')}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-xl border-l-4 border-indigo-600">
            <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">{t('about.team.tech')}</h3>
            <p class="text-gray-600 dark:text-gray-300">{t('about.team.tech.desc')}</p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-xl border-l-4 border-indigo-600">
            <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">{t('about.team.design')}</h3>
            <p class="text-gray-600 dark:text-gray-300">{t('about.team.design.desc')}</p>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-xl border-l-4 border-indigo-600">
            <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">{t('about.team.ops')}</h3>
            <p class="text-gray-600 dark:text-gray-300">{t('about.team.ops.desc')}</p>
          </div>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h2 class="text-2xl font-bold text-gray-800 dark:text-white mb-4">{t('about.contact')}</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          {t('about.contact.desc')} <a href="/zh/contact" class="text-indigo-600 hover:underline">{t('about.contact.link')}</a>。
        </p>
      </div>

    </div>
  </section>
</Layout>