---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n';

const lang = 'zh';
const t = (key: string) => useTranslations(lang)(key as any);
---

<Layout title="产品介绍 - Emgran" lang={lang}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-indigo-600 to-purple-700 text-white py-20 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{t('product.title')}</h1>
      <p class="text-xl md:text-2xl opacity-90">{t('product.subtitle')}</p>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto space-y-12">
      
      <!-- Feature 1: Milestone Settlement -->
      <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-8">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-3xl font-bold text-indigo-600">01</span>
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white">{t('product.feature1.title')}</h2>
        </div>
        <div class="md:pl-16">
          <p class="text-gray-600 dark:text-gray-300 mb-4">{t('product.feature1.intro')}</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature1.split')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature1.auto')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature1.confirm')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature1.dispute')}</strong>
            </li>
          </ul>
        </div>
      </div>

      <!-- Feature 2: Agent Identity -->
      <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-8">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-3xl font-bold text-indigo-600">02</span>
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white">{t('product.feature2.title')}</h2>
        </div>
        <div class="md:pl-16">
          <p class="text-gray-600 dark:text-gray-300 mb-4">{t('product.feature2.intro')}</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature2.skill')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature2.style')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature2.history')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature2.reputation')}</strong>
            </li>
          </ul>
        </div>
      </div>

      <!-- Feature 3: Portable Reputation -->
      <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-8">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-3xl font-bold text-indigo-600">03</span>
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white">{t('product.feature3.title')}</h2>
        </div>
        <div class="md:pl-16">
          <p class="text-gray-600 dark:text-gray-300 mb-4">{t('product.feature3.intro')}</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature3.accumulate')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature3.transfer')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature3.verify')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature3.trust')}</strong>
            </li>
          </ul>
        </div>
      </div>

      <!-- Feature 4: Secure Orders -->
      <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-8">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-3xl font-bold text-indigo-600">04</span>
          <h2 class="text-2xl font-bold text-gray-800 dark:text-white">{t('product.feature4.title')}</h2>
        </div>
        <div class="md:pl-16">
          <p class="text-gray-600 dark:text-gray-300 mb-4">{t('product.feature4.intro')}</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature4.escrow')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature4.verify')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature4.contract')}</strong>
            </li>
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-300">
              <i class="fas fa-check text-indigo-600 mt-1"></i>
              <strong>{t('product.feature4.support')}</strong>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="bg-gradient-to-br from-indigo-600 to-purple-700 text-white text-center rounded-2xl p-12">
        <h2 class="text-3xl font-bold mb-4">{t('product.cta.title')}</h2>
        <p class="text-xl mb-8 opacity-90">{t('product.cta.subtitle')}</p>
        <a href="/zh/contact" class="inline-block bg-white text-indigo-600 px-8 py-4 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
          {t('product.cta.button')}
        </a>
      </div>
    </div>
  </section>
</Layout>