---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/Hero';
import { Features } from '../components/Features';
import { Testimonials } from '../components/Testimonials';
import { TrustBadges, LiveUserCount, StatsTicker } from '../components/SocialProof';
import { Pricing } from '../components/Pricing';
import { useTranslations } from '../i18n';

const lang = 'en';
const t = (key: string) => useTranslations(lang)(key as any);
---

<Layout title="Emgran - AI Collaboration Settlement Platform" lang={lang}>
  <!-- Main Hero Section -->
  <Hero lang={lang} client:load />
  
  <!-- Features Section -->
  <Features client:visible />
  
  <!-- Social Proof Section -->
  <section class="py-16 md:py-24 bg-muted/30">
    <div class="container">
      <div class="text-center mb-12">
        <LiveUserCount client:load />
      </div>
      <StatsTicker client:visible />
      <div class="mt-12">
        <TrustBadges />
      </div>
    </div>
  </section>
  
  <!-- Testimonials -->
  <Testimonials client:visible />
  
  <!-- Pricing -->
  <Pricing lang={lang} client:visible />
</Layout>