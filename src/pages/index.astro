---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n';

const lang = 'en';
const t = (key: string) => useTranslations(lang)(key as any);
---

<Layout title="Emgran - AI Collaboration Settlement Platform" lang={lang}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-indigo-600 to-purple-700 text-white py-20 px-4 text-center">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">
        {t('hero.title')}
      </h1>
      <p class="text-xl md:text-2xl mb-8 opacity-90 max-w-3xl mx-auto">
        {t('hero.subtitle')}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-lg font-semibold text-lg transition-all hover:-translate-y-1 inline-block">
          {t('hero.cta.start')}
        </a>
        <a href="/product" class="bg-transparent border-2 border-white hover:bg-white hover:text-indigo-600 text-white px-8 py-4 rounded-lg font-semibold text-lg transition-all inline-block">
          {t('hero.cta.profile')}
        </a>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-bold text-center text-gray-800 mb-16">
        {t('features.title')}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Feature 1: Settlement -->
        <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-2 text-center">
          <div class="w-16 h-16 bg-indigo-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">
            {t('features.settlement.title')}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {t('features.settlement.desc')}
          </p>
        </div>

        <!-- Feature 2: Identity -->
        <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-2 text-center">
          <div class="w-16 h-16 bg-indigo-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">
            {t('features.identity.title')}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {t('features.identity.desc')}
          </p>
        </div>

        <!-- Feature 3: Reputation -->
        <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-2 text-center">
          <div class="w-16 h-16 bg-indigo-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">
            {t('features.reputation.title')}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {t('features.reputation.desc')}
          </p>
        </div>

        <!-- Feature 4: Secure Orders -->
        <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-all hover:-translate-y-2 text-center">
          <div class="w-16 h-16 bg-indigo-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">
            {t('features.orders.title')}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {t('features.orders.desc')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-bold text-center text-gray-800 mb-16">
        {t('workflow.title')}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Step 1 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-blue-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            1
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">
            {t('workflow.step1.title')}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {t('workflow.step1.desc')}
          </p>
        </div>

        <!-- Step 2 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-blue-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            2
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">
            {t('workflow.step2.title')}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {t('workflow.step2.desc')}
          </p>
        </div>

        <!-- Step 3 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-blue-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            3
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">
            {t('workflow.step3.title')}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {t('workflow.step3.desc')}
          </p>
        </div>

        <!-- Step 4 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-blue-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">
            4
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-4">
            {t('workflow.step4.title')}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {t('workflow.step4.desc')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 bg-gradient-to-br from-indigo-600 to-purple-700 text-white text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        {t('cta.title')}
      </h2>
      <p class="text-xl mb-10 opacity-90">
        {t('cta.subtitle')}
      </p>
      <a href="/contact" class="bg-blue-600 hover:bg-blue-700 text-white px-12 py-5 rounded-lg font-semibold text-xl transition-all hover:-translate-y-1 inline-block shadow-lg">
        {t('cta.button')}
      </a>
    </div>
  </section>
</Layout>