---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/Hero';
import { Features } from '../components/Features';
import { HowItWorks } from '../components/HowItWorks';
import { CTASection } from '../components/CTASection';
import { TrustBadges } from '../components/SocialProof';
import { Pricing } from '../components/Pricing';
import { BetaBanner } from '../components/BetaBanner';

const lang = 'en';
---

<Layout title="Emgran - AI Collaboration Settlement Platform" lang={lang}>
  <!-- Beta Banner (inside page, not fixed) -->
  <BetaBanner lang={lang} client:load />
  
  <!-- Hero Section -->
  <Hero lang={lang} client:load />
  
  <!-- Trust Badges -->
  <section class="py-8 bg-white dark:bg-slate-950 border-y border-slate-100 dark:border-slate-800">
    <div class="container">
      <TrustBadges />
    </div>
  </section>
  
  <!-- Features Section -->
  <Features lang={lang} client:visible />
  
  <!-- How It Works -->
  <HowItWorks lang={lang} client:visible />
  
  <!-- Pricing -->
  <Pricing lang={lang} client:visible />
  
  <!-- CTA Section -->
  <CTASection lang={lang} client:visible />
</Layout>